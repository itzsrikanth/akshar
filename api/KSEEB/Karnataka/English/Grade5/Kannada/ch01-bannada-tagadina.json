    {
      "exercise": "A",
      "id": "ex-a-q1",
      "text": "ಕಸ್ತೂರಿಯು ಏನನ್ನು ಕೊಂಡನು?",
      "translations": {
        "en": "What did Kasturi buy?"
      },
      "transliterations": {
        "devanagari": "कस्तूरियु एननु कोण्डनु?"
      },
      "type": "question"
    },
    {
      "id": "ex-a-q1-ans",
      "ref": "ex-a-q1",
      "text": "ಕಸ್ತೂರಿಯು ಬಣ್ಣದ ತಗಡಿನ ತುತ್ತೂರಿಯನ್ನು ಕೊಂಡನು.",
      "translations": {
        "en": "Kasturi bought the colorful tin trumpet."
      },
      "transliterations": {
        "devanagari": "कस्तूरियु बण्णद तगडिन तुत्तूरियन्नु कोण्डनु."
      },
      "type": "answer"
    },
    {
      "exercise": "A",
      "id": "ex-a-q2",
      "text": "ಕಸ್ತೂರಿ ಎಲ್ಲಿ ತುತ್ತೂರಿ ಊದಿದನು?",
      "translations": {
        "en": "Where did Kasturi blow the trumpet?"
      },
      "transliterations": {
        "devanagari": "कस्तूरि एल्लि तुत्तूरि ऊदिदनु?"
      },
      "type": "question"
    },
    {
      "id": "ex-a-q2-ans",
      "ref": "ex-a-q2",
      "text": "ಕಸ್ತೂರಿ ಕೊಳದ ಬಳಿ ತುತ್ತೂರಿ ಊದಿದನು.",
      "translations": {
        "en": "Kasturi blew the trumpet near the pond."
      },
      "transliterations": {
        "devanagari": "कस्तूरि कोळद बळि तुत्तूरि ऊदिदनु."
      },
      "type": "answer"
    },
    {
      "exercise": "A",
      "id": "ex-a-q3",
      "text": "ಕಸ್ತೂರಿಯು ತುತ್ತೂರಿಯನ್ನು ಯಾವಾಗ ಊದಿದನು?",
      "translations": {
        "en": "When did Kasturi blow the trumpet?"
