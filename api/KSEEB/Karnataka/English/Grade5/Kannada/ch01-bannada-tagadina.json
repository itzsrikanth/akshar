    "title": "ಬಣ್ಣದ ತಗಡಿನ ತುತ್ತೂರಿ"
  },
  "schemaVersion": "1.0",
  "segments": [
    {
      "id": "competency",
      "text": "ಪಠ್ಯವನ್ನು ಓದಿದ ಮೇಲೆ ಯಾರು? ಯಾವಾಗ? ಎಲ್ಲಿ? ಏನು? ಏಕೆ? ಎಂಬ ಪ್ರಶ್ನೆಗಳಿಗೆ ಉತ್ತರಿಸುವುದು.",
      "translations": {
        "en": "After reading the text, to answer the questions — Who? When? Where? What? Why?"
      },
      "transliterations": {
        "devanagari": "पठ्यवन्नु ओदिद मेले यारु? यावाग? एल्लि? एनु? एके? एंब प्रश्नेगळिगे उत्तरिसुवुदु."
      },
      "type": "competency"
    },
    {
      "id": "intro-1",
      "section": "intro",
      "text": "ಸಂತೋಷ, ದುಃಖ, ನೋವು — ಈ ಅನುಭವಗಳು ನಿನಗೂ ಆಗಿರಬಹುದಲ್ಲವೇ?",
      "translations": {
        "en": "Joy, sorrow, pain — haven't these experiences happened to you too?"
      },
      "transliterations": {
        "devanagari": "सन्तोष, दुःख, नोवु — ई अनुभवगळु निनगू आगिरबहुदल्लवे?"
      },
      "type": "prose"
    },
    {
      "id": "intro-2",
      "section": "intro",
      "text": "ನಿನ್ನ ಒಂದು ಅನುಭವವನ್ನು ನೆನೆಪಿಸಿಕೊ.",
      "translations": {
        "en": "Recall one experience of your own."
      },
      "transliterations": {
        "devanagari": "निन्न ओन्दु अनुभववन्नु नेनेपिसिको."
      },
      "type": "prose"
    },
    {
      "id": "intro-3",
      "section": "intro",
      "text": "ಅದಕ್ಕೆ ಒಂದು ಕಾರಣವೂ ಇರಬೇಕಲ್ಲವೇ?",
      "translations": {
        "en": "There must be a reason for it, mustn't there?"
      },
      "transliterations": {
        "devanagari": "अदक्के ओन्दु कारणवू इरबेकल्लवे?"
      },
      "type": "prose"
    },
    {
      "id": "intro-4",
      "section": "intro",
      "text": "ಈಗ ಇಲ್ಲಿನ ಘಟನೆಯನ್ನು ಗಮನಿಸು.",
      "translations": {
        "en": "Now observe the incident described here."
      },
      "transliterations": {
        "devanagari": "ईग इल्लिन घटनेयन्नु गमनिसु."
      },
      "type": "prose"
    },
    {
      "id": "intro-5",
      "section": "intro",
      "text": "ಸಂತೋಷ ಹಾಗೂ ದುಃಖಕ್ಕೆ ಕಾರಣವಾದ ಸಂದರ್ಭಗಳನ್ನು ಗುರುತಿಸು.",
      "translations": {
        "en": "Identify the situations that caused happiness and sadness."
      },
      "transliterations": {
        "devanagari": "सन्तोष हागू दुःखक्के कारणवाद सन्दर्भगळन्नु गुरुतिसु."
      },
      "type": "prose"
    },
    {
      "id": "poem-s1l1",
      "stanza": 1,
      "text": "ಬಣ್ಣದ ತಗಡಿನ ತುತ್ತೂರಿ",
      "translations": {
        "en": "The colorful tin trumpet,"
      },
      "transliterations": {
        "devanagari": "बण्णद तगडिन तुत्तूरि"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s1l2",
      "stanza": 1,
      "text": "ಕಾಸಿಗೆ ಕೊಂಡನು ಕಸ್ತೂರಿ",
      "translations": {
        "en": "Kasturi bought it for a coin."
      },
      "transliterations": {
        "devanagari": "कासिगे कोण्डनु कस्तूरि"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s1l3",
      "stanza": 1,
      "text": "ಸರಿಗಮಪದನಿಸ ಊದಿದನು",
      "translations": {
        "en": "He blew Sa-Ri-Ga-Ma-Pa-Da-Ni-Sa (ascending notes)."
      },
      "transliterations": {
        "devanagari": "सरिगमपदनिस ऊदिदनु"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s1l4",
      "stanza": 1,
      "text": "ಸನಿದಪ ಮಗರಿಸ ಊದಿದನು",
      "translations": {
        "en": "He blew Sa-Ni-Da-Pa-Ma-Ga-Ri-Sa (descending notes)."
      },
      "transliterations": {
        "devanagari": "सनिदप मगरिस ऊदिदनु"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s2l1",
      "stanza": 2,
      "text": "ತನಗೇ ತುತ್ತೂರಿ ಇದೆಯೆಂದ",
      "translations": {
        "en": "He boasted that only he has the trumpet,"
      },
      "transliterations": {
        "devanagari": "तनगे तुत्तूरि इदेयेन्द"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s2l2",
      "stanza": 2,
      "text": "ಬೇರಾರಿಗು ಅದು ಇಲ್ಲೆಂದ",
      "translations": {
        "en": "He said no one else has one."
      },
      "transliterations": {
        "devanagari": "बेरारिगू अदु इल्लेन्द"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s2l3",
      "stanza": 2,
      "text": "ಕಸ್ತೂರಿ ನಡೆದನು ಬೀದಿಯಲಿ",
      "translations": {
        "en": "Kasturi strutted down the street,"
      },
      "transliterations": {
        "devanagari": "कस्तूरि नडेदनु बीदियलि"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s2l4",
      "stanza": 2,
      "text": "ಜಂಭದ ಕೋಳಿಯ ರೀತಿಯಲಿ",
      "translations": {
        "en": "Like a proud, arrogant rooster."
      },
      "transliterations": {
        "devanagari": "जंभद कोळिय रीतियलि"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s3l1",
      "stanza": 3,
      "text": "ತುತ್ತೂರಿಯೂದುತ ಕೊಳದ ಬಳಿ",
      "translations": {
        "en": "Blowing his trumpet near the pond,"
      },
      "transliterations": {
        "devanagari": "तुत्तूरियूदुत कोळद बळि"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s3l2",
      "stanza": 3,
      "text": "ನಡೆದನು ಕಸ್ತೂರಿ ಸಂಜೆಯಲಿ",
      "translations": {
        "en": "Kasturi walked in the evening."
      },
      "transliterations": {
        "devanagari": "नडेदनु कस्तूरि संजेयलि"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s3l3",
      "stanza": 3,
      "text": "ಜಾರಿತು ನೀರಿಗೆ ತುತ್ತೂರಿ",
      "translations": {
        "en": "The trumpet slipped into the water."
      },
      "transliterations": {
        "devanagari": "जारितु नीरिगे तुत्तूरि"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s3l4",
      "stanza": 3,
      "text": "ಗಂಟಲು ಕಟ್ಟಿತು ನೀರೂರಿ",
      "translations": {
        "en": "His throat choked, tears welled in his eyes."
      },
      "transliterations": {
        "devanagari": "गंटलु कट्टितु नीरूरि"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s4l1",
      "stanza": 4,
      "text": "ಸರಿಗಮ ಊದಲು ನೋಡಿದನು",
      "translations": {
        "en": "He tried to blow Sa-Ri-Ga-Ma again,"
      },
      "transliterations": {
        "devanagari": "सरिगम ऊदलु नोडिदनु"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s4l2",
      "stanza": 4,
      "text": "ಗಗಗಗ ಸದ್ದನು ಮಾಡಿದನು",
      "translations": {
        "en": "It only made a ga-ga-ga-ga gurgling sound."
      },
      "transliterations": {
        "devanagari": "ग-ग-ग-ग सद्दनु माडिदनु"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s4l3",
      "stanza": 4,
      "text": "ಬಣ್ಣವು ನೀರಿನ ಪಾಲಾಯ್ತು",
      "translations": {
        "en": "The paint washed off into the water,"
      },
      "transliterations": {
        "devanagari": "बण्णवु नीरिन पालायतु"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s4l4",
      "stanza": 4,
      "text": "ಬಣ್ಣದ ತುತ್ತೂರಿ ಬೋಳಾಯ್ತು",
      "translations": {
        "en": "The colorful trumpet was stripped bare."
      },
      "transliterations": {
        "devanagari": "बण्णद तुत्तूरि बोळायतु"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s5l1",
      "stanza": 5,
      "text": "ಬಣ್ಣದ ತುತ್ತೂರಿ ಹಾಳಾಯ್ತು",
      "translations": {
        "en": "The colorful trumpet was ruined,"
      },
      "transliterations": {
        "devanagari": "बण्णद तुत्तूरि हाळायतु"
      },
      "type": "poem_line"
    },
    {
      "id": "poem-s5l2",
      "stanza": 5,
      "text": "ಜಂಭದ ಕೋಳಿಗೆ ಗೋಳಾಯ್ತು",
      "translations": {
        "en": "The arrogant rooster was left in grief."
      },
      "transliterations": {
        "devanagari": "जंभद कोळिगे गोळायतु"
      },
      "type": "poem_line"
    },
