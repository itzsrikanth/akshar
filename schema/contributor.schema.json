{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/itzsrikanth/akshar/schema/contributor.schema.json",
  "title": "Akshar transliteration/translation (contributor) file",
  "type": "object",
  "required": ["meta"],
  "minProperties": 2,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["source", "contributor", "license"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "script": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "contributor": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "labels": {
      "type": "object",
      "description": "Optional section-heading labels in this contributor's script/language, matching the same keys as the source file's labels.",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": { "type": "string", "minLength": 1 }
}
